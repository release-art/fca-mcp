# Environment Configuration
ENVIRONMENT=development
DEBUG=false

# Auth0 OAuth Settings
AUTH0_DOMAIN=your-tenant.auth0.com
AUTH0_AUDIENCE=https://your-api-audience
AUTH0_STORAGE_ENCRYPTION_KEY=AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA=
# Optional: for client credentials flow
# AUTH0_CLIENT_ID=your-client-id
# AUTH0_CLIENT_SECRET=your-client-secret
# AUTH0_JWT_SIGNING_KEY=your-jwt-signing-key

# Azure Storage Settings
# For local development with Azurite:
AZURE_CREDENTIAL=none
AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=http;AccountName=devstoreaccount1;AccountKey=Eby8vdM02xNOcqFlqUwJPLlmEtlCDXJ1OUzFT50uSRZ6IFsuFq2UVErCz4I6tq/K1SZFPTOtr/KBHBeksoGMGw==;BlobEndpoint=http://127.0.0.1:10000/devstoreaccount1;QueueEndpoint=http://127.0.0.1:10001/devstoreaccount1;TableEndpoint=http://127.0.0.1:10002/devstoreaccount1;

# OR for production with DefaultAzureCredential:
# AZURE_CREDENTIAL=default
# AZURE_STORAGE_ACCOUNT=your-storage-account
# Optional custom endpoints:
# AZURE_STORAGE_BLOB_ENDPOINT=https://your-account.blob.core.windows.net
# AZURE_STORAGE_QUEUE_ENDPOINT=https://your-account.queue.core.windows.net
# AZURE_STORAGE_TABLE_ENDPOINT=https://your-account.table.core.windows.net

# FCA API Credentials
FCA_API_USERNAME=your-email@example.com
FCA_API_KEY=your-fca-api-key
# Optional overrides
# FCA_API_BASE_URL=https://register.fca.org.uk
# FCA_API_TIMEOUT=30.0
# FCA_API_MAX_RETRIES=3

# Redis Cache Settings
REDIS_URL=redis://localhost:6379/0
# REDIS_PASSWORD=your-redis-password
REDIS_DB=0
REDIS_MAX_CONNECTIONS=10
REDIS_SOCKET_TIMEOUT=5.0
REDIS_SOCKET_CONNECT_TIMEOUT=5.0
REDIS_CACHE_TTL=3600
REDIS_ENABLED=true

# Server Configuration
SERVER_HOST=0.0.0.0
SERVER_PORT=8000
SERVER_HOSTNAME=localhost
# Optional: override auto-generated base URL
# SERVER_BASE_URL=https://api.example.com
SERVER_RELOAD=false
SERVER_WORKERS=1

# Logging Settings
LOG_LEVEL=INFO
LOG_FORMAT=text
# Optional: log to file
# LOG_FILE=/var/log/fca-mcp/app.log

# API Configuration
CORS_ORIGINS=["*"]
API_VERSION=v1

